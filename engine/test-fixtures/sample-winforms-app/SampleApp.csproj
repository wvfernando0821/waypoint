<Project Sdk="Microsoft.NET.Sdk">
  <!--
    Synthetic fixture for M1 testing only — a minimal, representative
    WinForms app, not a real client codebase. Uses the classic-style
    references (System.Windows.Forms) that a legacy app would have.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Data" />
  </ItemGroup>
</Project>
